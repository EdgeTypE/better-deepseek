{
  "manifest_version": 3,
  "name": "Better DeepSeek",
  "version": "0.1.9",
  "description": "Enhanced UX layer for DeepSeek with hidden prompts, tools, memory, document generation, and long-work packaging.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://kimi.moonshot.cn/*",
    "https://codeload.github.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://cdnjs.cloudflare.com/*",
    "https://pyscript.net/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://kimi.moonshot.cn/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "sandbox.html", "sandbox.js", "static/loading/*.svg"],
      "matches": [
        "https://chat.deepseek.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://kimi.moonshot.cn/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "icons": {
    "16": "static/icons/icon16.png",
    "32": "static/icons/icon32.png",
    "48": "static/icons/icon48.png",
    "128": "static/icons/icon128.png"
  },
  "action": {
    "default_title": "Better DeepSeek",
    "default_icon": {
      "16": "static/icons/icon16.png",
      "32": "static/icons/icon32.png",
      "48": "static/icons/icon48.png",
      "128": "static/icons/icon128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups; script-src 'self' 'unsafe-eval' 'unsafe-inline' blob: https://cdnjs.cloudflare.com; object-src 'self'"
  }
}
