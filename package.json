{
  "name": "better-deepseek",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node build.js --dev",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "node build.js --target=chrome",
    "build:firefox": "node build.js --target=firefox",
    "build:source": "node build.js --source",
    "sanitize": "node scripts/sanitize-dist.js",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:ci": "npm run build:chrome && npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@playwright/test": "^1.54.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.1.0",
    "svelte": "^5.28.2",
    "vite": "^6.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "docx": "^9.6.1",
    "fflate": "^0.8.2",
    "html2canvas": "^1.4.1",
    "ignore": "^7.0.5",
    "marked": "^18.0.3",
    "pptxgenjs": "^4.0.1",
    "turndown": "^7.2.4",
    "xlsx": "^0.18.5",
    "youtube-transcript": "^1.3.0"
  }
}
